<script is:inline>
  (() => {
    try {
      const savedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia(
        '(prefers-color-scheme: dark)'
      ).matches;

      const shouldUseDark =
        savedTheme === 'dark' ||
        (savedTheme === null && prefersDark);

      document.documentElement.classList.toggle(
        'dark',
        shouldUseDark
      );
    } catch {
      const prefersDark = window.matchMedia(
        '(prefers-color-scheme: dark)'
      ).matches;

      document.documentElement.classList.toggle(
        'dark',
        prefersDark
      );
    }
  })();
</script>